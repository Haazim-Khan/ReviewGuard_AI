<!DOCTYPE html>
<html>

<head>

  <title>Review History</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >

</head>

<body>

<div class="container mt-5">

  <h1 class="mb-4">📜 Review History</h1>

  <table class="table table-bordered">

    <thead>

      <tr>

        <th>Product</th>

        <th>Rating</th>

        <th>Prediction</th>

        <th>Confidence</th>

        <th>Date</th>

      </tr>

    </thead>

    <tbody>

      <% reviews.forEach(review => { %>

        <tr>

          <td><%= review.productName %></td>

          <td><%= review.rating %></td>

          <td><%= review.prediction %></td>

          <td><%= review.confidence %>%</td>

          <td><%= review.createdAt.toDateString() %></td>

        </tr>

      <% }) %>

    </tbody>

  </table>

</div>

</body>
</html>